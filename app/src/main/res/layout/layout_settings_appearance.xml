<merge xmlns:tools="http://schemas.android.com/tools"
       xmlns:android="http://schemas.android.com/apk/res/android"
       xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        style="@style/SunsetTimeSettingsGroupLayout"
        android:id="@+id/settings_group_appearance">

        <LinearLayout android:id="@+id/settings_group_appearance_header"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            style="@style/SunsetTimeSettingsGroupHeader">

            <TextView style="@style/SunsetTimeSettingsGroupTitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/settings_appearance" />

            <View android:layout_width="0dp" android:layout_weight="1" android:layout_height="1dp" android:background="@null" />

            <CheckBox android:id="@+id/settings_group_appearance_button"
                style="@style/SunsetTimeSettingsExpandCheckBox"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />

        </LinearLayout>

        <LinearLayout android:id="@+id/settings_group_appearance_content"
            style="@style/SunsetTimeSettingsGroupContentArea"
            android:layout_width="match_parent" android:layout_height="wrap_content">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingLeft="@dimen/widget_settings_label_padding_left" android:paddingRight="8dp"
            android:paddingStart="@dimen/widget_settings_label_padding_left" android:paddingEnd="8dp">

            <TextView android:labelFor="@+id/appwidget_appearance_theme"
                android:id="@+id/appwidget_appearance_theme_label"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/settings_appearance_theme" android:layout_gravity="center_vertical"
                android:textSize="?attr/text_size_small" />

            <Spinner android:id="@+id/appwidget_appearance_theme" android:dropDownVerticalOffset="16sp"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />

            <com.forrestguice.support.widget.ImageButton android:id="@+id/appwidget_appearance_theme_button"
                style="@style/Widget.AppCompat.ActionButton"
                android:layout_height="wrap_content" android:layout_width="wrap_content"
                android:src="@drawable/ic_palette"  android:tint="?attr/colorAccent"
                android:contentDescription="@string/themes_action_editTheme" />

        </LinearLayout>


            <com.forrestguice.support.constraint.ConstraintLayout android:visibility="gone"
                android:id="@+id/appwidget_appearance_typeface_group"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                tools:ignore="MissingConstraints"
                android:paddingStart="@dimen/widget_settings_check_padding_left"
                android:paddingEnd="@dimen/widget_settings_check_padding_left"
                android:paddingBottom="4dp" android:layout_marginBottom="4dp">

                <com.forrestguice.suntimeswidget.settings.colors.ColorChooserView
                    android:id="@+id/appwidget_appearance_typeface_color"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:hintText="@string/themes_configHint_themeColorText"
                    app:labelText="@string/themes_configLabel_themeColorText"
                    app:reverse="false" />

                <Button style="@style/Widget.AppCompat.Button.Borderless"
                    android:id="@+id/appwidget_appearance_typeface_clear"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/appwidget_appearance_typeface_color"
                    android:layout_marginStart="16dp" android:layout_marginLeft="16dp"
                    android:layout_marginEnd="16dp" android:layout_marginRight="16dp"
                    android:text="@string/action_restoreDefaults" />

                <LinearLayout android:id="@+id/appwidget_appearance_typeface_layout"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="start"
                    android:layout_marginStart="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/appwidget_appearance_typeface_color">

                    <TextView android:labelFor="@+id/appwidget_appearance_typeface"
                        android:id="@+id/appwidget_appearance_typeface_label"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/settings_appearance_fontfamily" android:layout_gravity="center_vertical"
                        android:textSize="?attr/text_size_small" />

                    <Spinner android:id="@+id/appwidget_appearance_typeface"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                </LinearLayout>

                <com.forrestguice.support.constraint.helper.Flow
                    android:id="@+id/flow1"
                    app:constraint_referenced_ids="appwidget_appearance_typeface_bold,appwidget_appearance_typeface_italic,appwidget_appearance_typeface_outline"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@+id/appwidget_appearance_typeface_layout"
                    app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
                    app:flow_horizontalAlign="start" app:flow_horizontalBias="0"
                    app:flow_verticalBias="0" app:flow_verticalGap="0dp"
                    app:flow_horizontalGap="8dp" app:flow_maxElementsWrap="5" app:flow_wrapMode="chain" />

                <CheckBox android:id="@+id/appwidget_appearance_typeface_bold" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"  android:textSize="?attr/text_size_small"
                    android:text="@string/themes_configLabel_themeBoldTime"
                    android:layout_marginLeft="8dp" android:layout_marginStart="8dp" />

                <CheckBox android:id="@+id/appwidget_appearance_typeface_italic" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"  android:textSize="?attr/text_size_small"
                    android:text="@string/themes_configLabel_themeItalicTime"
                    android:layout_marginLeft="8dp" android:layout_marginStart="8dp" />

                <CheckBox android:id="@+id/appwidget_appearance_typeface_outline" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"  android:textSize="?attr/text_size_small"
                    android:text="@string/themes_configLabel_themeOutlineTime"
                    android:layout_marginLeft="8dp" android:layout_marginStart="8dp" />

            </com.forrestguice.support.constraint.ConstraintLayout>

            <CheckBox android:id="@+id/appwidget_appearance_scaleText" android:layout_width="match_parent"
            android:layout_marginLeft="@dimen/widget_settings_check_padding_left" android:layout_marginRight="8dp"
            android:layout_marginStart="@dimen/widget_settings_check_padding_left" android:layout_marginEnd="8dp"
            android:layout_height="wrap_content"  android:textSize="?attr/text_size_small" android:text="@string/settings_appearance_scaleText" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/widget_settings_label_padding_left" android:paddingRight="8dp"
            android:paddingStart="@dimen/widget_settings_label_padding_left" android:paddingEnd="8dp"
            android:paddingTop="8dp" android:paddingBottom="4dp">

            <TextView android:labelFor="@+id/appwidget_appearance_gravity"
                android:id="@+id/appwidget_appearance_gravity_label"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="?attr/text_size_small" android:text="@string/settings_appearance_gravity" android:layout_gravity="center_vertical" />

            <Spinner android:id="@+id/appwidget_appearance_gravity"
                android:dropDownVerticalOffset="16sp"
                android:layout_width="match_parent" android:layout_height="wrap_content" />

        </LinearLayout>

        <CheckBox android:id="@+id/appwidget_appearance_scaleBase" android:layout_width="match_parent"
            android:layout_marginLeft="@dimen/widget_settings_check_padding_left" android:layout_marginRight="8dp"
            android:layout_marginStart="@dimen/widget_settings_check_padding_left" android:layout_marginEnd="8dp"
            android:textSize="?attr/text_size_small"
            android:layout_height="wrap_content" android:text="@string/settings_appearance_scaleBase" />

        </LinearLayout>
    </LinearLayout>

</merge>